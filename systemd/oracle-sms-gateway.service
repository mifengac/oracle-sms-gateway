[Unit]
Description=Oracle SMS Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/longshao/project/oracle-sms-gateway
EnvironmentFile=/home/longshao/project/oracle-sms-gateway/.env
Environment=LD_LIBRARY_PATH=/home/longshao/project/oracle-sms-gateway/instantclient_11_2
ExecStart=/home/longshao/project/oracle-sms-gateway/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 18080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
